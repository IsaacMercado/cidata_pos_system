{
  "name": "pos-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pos-db --remote",
    "db:seed:local": "wrangler d1 execute pos-db --local --file=./src/worker/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute pos-db --remote --file=./src/worker/db/seed.sql",
    "db:triggers:local": "wrangler d1 execute pos-db --local --file=./src/worker/db/triggers.sql",
    "db:triggers:remote": "wrangler d1 execute pos-db --remote --file=./src/worker/db/triggers.sql",
    "cf-typegen": "wrangler types",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0",
    "idb": "^8.0.0",
    "lucide-react": "^1.23.0",
    "preact": "^10.26.0",
    "react-hook-form": "^7.81.0",
    "tailwindcss": "^4.3.0",
    "wouter-preact": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250201.0",
    "@preact/preset-vite": "^2.10.0",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "wrangler": "^4.0.0"
  }
}
